apiVersion: v1                                                                                                                  
  kind: Secret                                                                                                                    
  metadata:
    name: ecommerce-back-db                                                                                                       
    namespace: lapaltech                                                                                                          
  type: Opaque                                                                                                                    
  stringData:     
    url: "postgres://user:password@host:5432/dbname?sslmode=disable"
  ---                                                                                                                             
  apiVersion: v1
  kind: Secret                                                                                                                    
  metadata:       
    name: ecommerce-back-redis
    namespace: lapaltech
  type: Opaque
  stringData:
    addr: "address"                                                                             
    password: "your-redis-password"